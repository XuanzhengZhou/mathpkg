# ── main ───────────────────────────────────────────────────────────────────

def main():
    parser = _build_parser()
    args = parser.parse_args()
    if hasattr(args, "func"):
        args.func(args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()

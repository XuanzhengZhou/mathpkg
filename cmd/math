#!/usr/bin/env python3
"""
math — the mathpkg CLI (modeled after apt-get / apt).

Subcommands:
    math source list       List all enabled sources
    math update            Rebuild the knowledge cache from all sources
    math show <concept_id> Display a concept's details
"""

from __future__ import annotations

import argparse
import logging
import os
import sys

# Ensure the mathpkg package is on sys.path even when invoked directly.
_PROJECT_ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
if _PROJECT_ROOT not in sys.path:
    sys.path.insert(0, _PROJECT_ROOT)

# Absolute paths for key project files.
DEFAULT_SOURCES_PATH = os.path.join(_PROJECT_ROOT, "sources.yaml")
DEFAULT_DB_PATH = os.path.join(_PROJECT_ROOT, "graph.db")

logging.basicConfig(
    level=logging.INFO,
    format="%(levelname)s: %(message)s",
)
logger = logging.getLogger("math")


def _build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="math",
        description="mathpkg — math knowledge package manager",
    )
    sub = parser.add_subparsers(dest="command", required=True)

    # ── math source list ──────────────────────────────────────────────
    sp_source = sub.add_parser("source", help="Manage knowledge sources")
    sp_source_sub = sp_source.add_subparsers(dest="source_action")
    sp_source_list = sp_source_sub.add_parser("list", help="List all enabled sources")
    sp_source_list.set_defaults(func=cmd_source_list)

    # ── math update ───────────────────────────────────────────────────
    sp_update = sub.add_parser("update", help="Rebuild knowledge cache")
    sp_update.set_defaults(func=cmd_update)
    sp_update.add_argument(
        "--db", default=DEFAULT_DB_PATH,
        help="Path to SQLite cache (default: graph.db in project root)",
    )
    sp_update.add_argument(
        "--sources", default=DEFAULT_SOURCES_PATH,
        help="Path to sources.yaml (default: sources.yaml in project root)",
    )

    # ── math show ─────────────────────────────────────────────────────
    sp_show = sub.add_parser("show", help="Show details of a concept")
    sp_show.add_argument("concept", help="Concept ID to display")
    sp_show.add_argument(
        "--db", default=DEFAULT_DB_PATH,
        help="Path to SQLite cache",
    )
    sp_show.set_defaults(func=cmd_show)

    # ── math install <concept> ───────────────────────────────────────
    sp_install = sub.add_parser("install", help="Generate learning path for a concept")
    sp_install.add_argument("concept", help="Target concept ID")
    sp_install.add_argument("--db", default=DEFAULT_DB_PATH)
    sp_install.add_argument("--no-recommends", action="store_true",
                            help="Exclude recommended dependencies")
    sp_install.set_defaults(func=cmd_install)

    # ── math mark <concept> <state> ──────────────────────────────────
    sp_mark = sub.add_parser("mark", help="Mark a concept's learning state")
    sp_mark.add_argument("concept", help="Concept ID")
    sp_mark.add_argument("state", choices=["not_learned","learning","learned","mastered","stuck"])
    sp_mark.add_argument("--source", default=None, help="Source textbook")
    sp_mark.add_argument("--note", default=None, help="Optional note")
    sp_mark.set_defaults(func=cmd_mark)

    # ── math status ──────────────────────────────────────────────────
    sp_status = sub.add_parser("status", help="Show learning progress")
    sp_status.add_argument("--db", default=DEFAULT_DB_PATH)
    sp_status.set_defaults(func=cmd_status)

    # ── math verify <concept> ────────────────────────────────────────
    sp_verify = sub.add_parser("verify", help="Verify Lean theorem in Mathlib4")
    sp_verify.add_argument("concept", nargs="?", default=None,
                           help="Concept ID (omit with --all to verify all)")
    sp_verify.add_argument("--all", action="store_true",
                           help="Verify all concepts in cache")
    sp_verify.add_argument("--db", default=DEFAULT_DB_PATH)
    sp_verify.set_defaults(func=cmd_verify)

    # ── math lean <concept> ────────────────────────────────────────
    sp_lean = sub.add_parser("lean", help="Show/verify Lean code for a concept")
    sp_lean.add_argument("concept", nargs="?", default=None,
                         help="Concept ID to show Lean code for")
    sp_lean.add_argument("--build", action="store_true",
                         help="Build Lean project and report status")
    sp_lean.add_argument("--db", default=DEFAULT_DB_PATH)
    sp_lean.set_defaults(func=cmd_lean)

    return parser


# ── command handlers ───────────────────────────────────────────────────────

def cmd_source_list(args):
    """Print all enabled sources."""
    from mathpkg.source.source_list import SourceList

    sl = SourceList(filepath=DEFAULT_SOURCES_PATH)
    if not sl.enabled:
        print("No enabled sources found.")
        return
    print(f"{'Name':<30} {'Type':<10} {'URI'}")
    print("-" * 70)
    for src in sl.enabled:
        print(f"{src.name:<30} {src.type:<10} {src.uri}")


def cmd_update(args):
    """Rebuild the knowledge cache from all enabled sources."""
    from mathpkg.source.source_list import SourceList
    from mathpkg.graph.cache import KnowledgeCache

    print("▸ Reading sources...")
    sl = SourceList(filepath=args.sources)
    if not sl.enabled:
        print("No enabled sources found. Add a source to sources.yaml first.")
        sys.exit(1)

    cache = KnowledgeCache(db_path=args.db)
    try:
        for src in sl.enabled:
            if src.type == "local":
                if not os.path.isdir(src.uri):
                    logger.warning("Source '%s': URI %s does not exist, skipping.", src.name, src.uri)
                    continue
                print(f"▸ Updating from source: {src.name} ({src.uri})")
                cache.rebuild_from_dir(src.uri)
            else:
                logger.warning("Source type '%s' not yet implemented (source: %s)", src.type, src.name)

        total = len(cache.get_all_concepts())
        print(f"✓ Cache updated successfully ({total} concepts)")
    finally:
        cache.close()


def cmd_show(args):
    """Display detailed information about a single concept."""
    from mathpkg.graph.cache import KnowledgeCache

    if not os.path.isfile(args.db):
        print(f"Error: cache database not found at {args.db}")
        print("Run 'math update' first to build the cache.")
        sys.exit(1)

    cache = KnowledgeCache(db_path=args.db)
    try:
        info = cache.find_concept(args.concept)
        if info is None:
            print(f"Concept '{args.concept}' not found in cache.")
            # List suggestions
            all_cids = cache.get_all_concepts()
            if all_cids:
                print(f"Available concepts ({len(all_cids)}):")
                for cid in all_cids:
                    print(f"  - {cid}")
            sys.exit(1)

        print("═" * 60)
        print(f"Concept: {info['id']}")
        print(f"  Name (en): {info['name_en']}")
        print(f"  Name (zh): {info['name_zh']}")
        print(f"  Type:      {info['type']}")
        print(f"  Lean:      {info['lean_status']}")
        print(f"  Confidence: {info['confidence']:.2f}")
        print("─" * 60)

        # Dependencies
        for dep_type, label in [
            ("required", "Required"),
            ("recommended", "Recommended"),
            ("suggested", "Suggested"),
        ]:
            deps = cache.get_dependencies(args.concept, dep_type)
            print(f"  {label} ({len(deps)}): {', '.join(deps) if deps else '(none)'}")

        # Versions
        versions = cache.get_versions(args.concept)
        if versions:
            print("─" * 60)
            print("  Sources / Versions:")
            for v in versions:
                parts = [f"    {v['source']}"]
                if v["author"]:
                    parts.append(f"by {v['author']}")
                if v["chapter"]:
                    parts.append(f"Ch.{v['chapter']}")
                if v["section"]:
                    parts.append(f"§{v['section']}")
                if v["pages"]:
                    parts.append(f"pp.{v['pages']}")
                if v["theorem_number"]:
                    parts.append(f"Thm.{v['theorem_number']}")
                print(", ".join(parts))

        # Reverse dependencies (who depends on this)
        dependents = cache.get_dependents(args.concept)
        if dependents:
            print("─" * 60)
            print(f"  Dependents ({len(dependents)}): {', '.join(dependents)}")

        print("═" * 60)

    finally:
        cache.close()


# ── math install ─────────────────────────────────────────────────────────────

def cmd_install(args):
    """Generate and display a learning path for the target concept."""
    from mathpkg.graph.cache import KnowledgeCache
    from mathpkg.resolver.solver import LearningPathResolver
    from mathpkg.resolver.policy import Policy
    from mathpkg.status.user_state import UserState

    if not os.path.isfile(args.db):
        print(f"Error: cache database not found at {args.db}")
        print("Run 'math update' first to build the cache.")
        sys.exit(1)

    cache = KnowledgeCache(db_path=args.db)
    try:
        if cache.find_concept(args.concept) is None:
            print(f"Concept '{args.concept}' not found in cache.")
            sys.exit(1)

        user = UserState()
        policy = Policy(install_recommends=not args.no_recommends)
        resolver = LearningPathResolver(cache, user, policy)

        try:
            path = resolver.resolve(args.concept)
        except ValueError as e:
            print(f"Error: {e}")
            sys.exit(1)

        # ── pretty-print the learning path ────────────────────────────
        info = cache.find_concept(args.concept)
        print(f"\n解析依赖中...")
        print(f"{'★' if info['type']=='theorem' else '•'} {args.concept} "
              f"({info.get('name_zh', args.concept)})")

        # Tree display
        _print_dep_tree(args.concept, cache, user, max_depth=3)

        if not path.steps:
            print("\n✅ 你已掌握所有必要的前置知识！可以直接学习。")
            return

        print(f"\n{'═'*50}")
        print(f"学习路径（{path.new_to_learn} 个新概念，预计 {path.estimated_total_minutes//60:.1f} 小时）")
        print(f"{'═'*50}")

        for i, step in enumerate(path.steps, 1):
            lean_icon = "✅" if step.lean_verified else "⬜"
            star = "★" if step.type == "theorem" else " "
            print(f"  {i:2d}.{star} {step.concept_id:<30} (~{step.estimated_minutes/60:.1f}h)  Lean: {lean_icon}")
            if step.sources:
                print(f"      教材: {', '.join(step.sources[:2])}")

        print(f"\nLean 验证: {path.lean_verified_count}/{path.new_to_learn}")
        if path.suggested_followups:
            print(f"建议后续: {', '.join(path.suggested_followups[:3])}")
        print(f"{'═'*50}")

    finally:
        cache.close()


def _print_dep_tree(concept_id, cache, user, prefix="", is_last=True,
                    visited=None, depth=0, max_depth=4):
    """Recursively print dependency tree with status indicators."""
    if depth >= max_depth:
        if any(True for _ in cache.get_dependencies(concept_id, "required")):
            print(f"{prefix}└── ...")
        return
    if visited is None:
        visited = set()
    if concept_id in visited:
        return
    visited.add(concept_id)

    deps = cache.get_dependencies(concept_id, "required")
    for i, dep in enumerate(deps):
        is_last_dep = (i == len(deps) - 1)
        connector = "└──" if is_last_dep else "├──"
        status = "✅ (已掌握)" if user.is_mastered(dep) else ""
        info = cache.find_concept(dep)
        name = info.get("name_zh", dep) if info else dep
        print(f"{prefix}{connector} {dep} {status}".rstrip())
        if not user.is_mastered(dep):
            new_prefix = prefix + ("    " if is_last_dep else "│   ")
            _print_dep_tree(dep, cache, user, new_prefix, True, visited, depth+1, max_depth)


# ── math mark ────────────────────────────────────────────────────────────────

def cmd_mark(args):
    """Update a concept's learning state."""
    from mathpkg.status.user_state import UserState

    user = UserState()
    kwargs = {}
    if args.source:
        kwargs["learned_from"] = args.source
    if args.note:
        kwargs["notes"] = args.note
    user.mark(args.concept, args.state, **kwargs)
    user.save()
    print(f"✓ {args.concept} → {args.state}")


# ── math status ──────────────────────────────────────────────────────────────

def cmd_status(args):
    """Display current learning progress and unlockable concepts."""
    from mathpkg.status.user_state import UserState
    from mathpkg.graph.cache import KnowledgeCache

    user = UserState()
    mastered = user.get_mastered()
    in_progress = user.get_in_progress()
    stuck = [c for c in user._data.get("concepts", {})
             if user._data["concepts"][c].get("state") == "stuck"]

    # Determine unlockable concepts (all deps mastered)
    unlockable = []
    if os.path.isfile(args.db):
        cache = KnowledgeCache(db_path=args.db)
        try:
            for cid in cache.get_all_concepts():
                if user.is_mastered(cid):
                    continue
                deps = cache.get_dependencies(cid, "required")
                if all(user.is_mastered(d) for d in deps):
                    unlockable.append(cid)
        finally:
            cache.close()

    total_known = len(mastered) + len(in_progress)
    total = total_known + (len(unlockable) - len(in_progress))

    print(f"\n{'═'*40}")
    print(f"  学习进度")
    print(f"{'═'*40}")
    print(f"  已掌握: {len(mastered)}")
    print(f"  学习中: {len(in_progress)}")
    print(f"  卡住:   {len(stuck)}")
    if unlockable:
        print(f"\n  下一步建议 (已解锁):")
        for cid in unlockable[:8]:
            marker = "🔄" if cid in in_progress else "📖"
            print(f"    {marker} {cid}")
    print(f"{'═'*40}\n")


# ── math verify ──────────────────────────────────────────────────────────────

def cmd_verify(args):
    """Verify Lean theorem references against Mathlib4 source."""
    from mathpkg.graph.cache import KnowledgeCache
    from mathpkg.pipeline.lean_check import verify_concept, verify_all

    if not os.path.isfile(args.db):
        print(f"Error: cache database not found at {args.db}")
        print("Run 'math update' first to build the cache.")
        sys.exit(1)

    cache = KnowledgeCache(db_path=args.db)
    try:
        if args.all:
            print("验证所有概念...")
            results = verify_all(cache)
            found = sum(1 for r in results if r.found)
            not_found = sum(1 for r in results if not r.found and r.match_type != "not_declared")
            not_declared = sum(1 for r in results if r.match_type == "not_declared")
            print(f"\n已验证: {len(results)}")
            print(f"  ✅ 找到: {found}")
            print(f"  ❌ 未找到: {not_found}")
            print(f"  ⬜ 未声明Lean定理: {not_declared}")
            if not_found:
                print("\n未找到的定理:")
                for r in results:
                    if not r.found and r.match_type != "not_declared":
                        print(f"  ❌ {r.concept_id}: {r.theorem_name}")
        elif args.concept:
            if cache.find_concept(args.concept) is None:
                print(f"Concept '{args.concept}' not found.")
                sys.exit(1)
            result = verify_concept(args.concept, cache)
            if result.found:
                print(f"✅ {result.theorem_name}")
                print(f"   → {result.file_path}:{result.line_number}")
                print(f"   状态: {result.match_type}")
            elif result.match_type == "not_declared":
                print(f"⬜ {args.concept}: 未声明 Lean 定理")
            else:
                print(f"❌ {result.theorem_name}: 在 Mathlib4 中未找到")
        else:
            print("Usage: math verify <concept> | math verify --all")
    finally:
        cache.close()


